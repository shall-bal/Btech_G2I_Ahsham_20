#include <stdio.h>
int main()
{
    int n, i;
    int a[100];
    int count_even = 0, count_odd = 0;
    printf("Enter number of elements: ");
    scanf("%d", &n);
    printf("Enter elements:\n");
    for(i = 0; i < n; i++)
    {
        scanf("%d", &a[i]);
    }
    for(i = 0; i < n; i++)
    {
        if(a[i] % 2 == 0)
            count_even++;
        else
            count_odd++;
    }
    printf("Even count = %d\n", count_even);
    printf("Odd count = %d\n", count_odd);
    return 0;
}
